# ARIA — environment template. Copy to .env and fill in. NEVER commit real values.

# --- LLM brain ---
ANTHROPIC_API_KEY=                  # console.anthropic.com -> API Keys
BRAIN_MODE=mock                     # mock | live
BRAIN_MODEL=claude-haiku-4-5        # claude-sonnet-4-6 for the judged live week

# --- CoinMarketCap Agent Hub ---
CMC_MCP_API_KEY=                    # pro.coinmarketcap.com dashboard

# --- Trust Wallet Agent Kit ---
# Access ID + HMAC Secret are stored by `twak init` in ~/.twak/credentials.json
TWAK_WALLET_PASSWORD=               # unlocks the embedded agent wallet (dedicated hackathon wallet ONLY)

# --- BNB Smart Chain ---
NETWORK=testnet                     # testnet | mainnet
BSC_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# --- Risk parameters ---
MAX_DRAWDOWN_PCT=30
HALT_DRAWDOWN_PCT=20
MAX_POSITION_PCT=15
