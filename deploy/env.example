# ARIA server config — copy to ../.env (repo root) and fill in. NEVER commit .env.
#   cp deploy/env.example .env   &&   nano .env   &&   chmod 600 .env

# --- secrets ---
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
CMC_MCP_API_KEY=REPLACE_ME
TWAK_WALLET_PASSWORD=REPLACE_ME          # only used when EXECUTION_MODE=live

# --- run mode: PAPER testing (no funds, simulated fills on live signals) ---
BRAIN_MODE=live
BRAIN_MODEL=claude-haiku-4-5
EXECUTION_MODE=paper
SIGNALS_MODE=live
NETWORK=testnet
ARIA_DB=paper.sqlite3

# --- for the LIVE competition week, change to:
#   EXECUTION_MODE=live
#   NETWORK=mainnet
#   ARIA_DB=aria.sqlite3
# (and the wallet must be funded + registered — see docs/RUNBOOK.md)
